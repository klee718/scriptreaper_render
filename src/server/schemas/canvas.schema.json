{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SuperPlaneCanvas",
  "type": "object",
  "required": ["version", "name", "trigger", "steps"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[a-z0-9-]+$" },
    "trigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["schedule", "manual", "webhook"] },
        "schedule": {
          "type": "object",
          "properties": {
            "cron": { "type": "string" }
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "source": { "type": "string" },
            "event": { "type": "string" }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "component"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "component": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "runWhen": { "type": "string", "enum": ["always", "success", "failure"] },
          "inputs": { "type": "object" },
          "retry": {
            "type": "object",
            "properties": {
              "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 10 },
              "backoffSeconds": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
